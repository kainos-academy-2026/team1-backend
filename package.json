{
	"name": "team1-backend",
	"version": "1.0.0",
	"description": "Kainos Job Roles API",
	"main": "dist/index.js",
	"scripts": {
		"build": "npm run prisma:generate && tsc",
		"dev": "tsx watch src/index.ts",
		"prisma:generate": "prisma generate",
		"seed": "tsx prisma/seed.ts",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"ci:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:bdd": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js tests/bdd/features/**/*.feature --import tests/bdd/steps/**/*.ts --import tests/bdd/support/**/*.ts --format progress --format json:test-reports/cucumber-$(date +%F).json --retry 3",
		"test:framework": "npm run test && npm run test:bdd"
	},
	"vitest": {
		"environment": "node"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1087.0",
		"@aws-sdk/s3-request-presigner": "^3.1087.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"argon2": "^0.44.0",
		"cors": "^2.8.6",
		"express": "^4.18.2",
		"jose": "^6.2.3",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@cucumber/cucumber": "^13.2.0",
		"@cucumber/pretty-formatter": "^4.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^4.17.21",
		"@types/node": "^20.19.43",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"dotenv": "^17.4.2",
		"prisma": "^7.8.0",
		"supertest": "^7.0.0",
		"ts-node-dev": "^2.0.0",
		"tsx": "^4.23.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.10"
	}
}
