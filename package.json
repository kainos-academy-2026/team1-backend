{
	"name": "team1-backend",
	"version": "1.0.0",
	"description": "Kainos Job Roles API",
	"main": "dist/index.js",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"ci:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"vitest": {
		"environment": "node"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"dotenv": "^16.3.1",
		"express": "^4.18.2",
		"pg": "^8.22.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/express": "^4.17.21",
		"@types/node": "^20.11.5",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"prisma": "^6.19.3",
		"supertest": "^7.0.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.10"
	}
}
